--- a/src/ccdf/inference/sampling.py
+++ b/src/ccdf/inference/sampling.py
@@ -11,3 +11,14 @@ def sample(logits: torch.Tensor, temperature: float = 0.0) -> torch.Tensor:
     batch, sequence, vocab = logits.shape
     probs = torch.softmax(logits.reshape(-1, vocab) / temperature, dim=-1)
     return torch.multinomial(probs, num_samples=1).reshape(batch, sequence)
+
+
+def sample_verifier_logits(logits: torch.Tensor, temperature: float = 0.0) -> torch.Tensor:
+    """Greedy verifier selection stable across one-ULP block-shape rounding."""
+
+    if temperature >= 1e-5:
+        return sample(logits, temperature)
+    maximum = logits.amax(dim=-1, keepdim=True)
+    previous = torch.nextafter(maximum, torch.full_like(maximum, -torch.inf))
+    candidates = logits >= previous
+    return candidates.to(torch.uint8).argmax(dim=-1)
