{
  "gate_criteria": {
    "row_count": {
      "task87_target": 10,
      "task88_target": 30,
      "must_match_target": true
    },
    "empty_output_count": {
      "threshold": 0,
      "fail_if_greater": true
    },
    "repetition_count": {
      "threshold": 2,
      "fail_if_greater": true
    },
    "hit_cap_count": {
      "threshold": 3,
      "fail_if_greater": true
    },
    "quality_metrics": {
      "gsm8k_short": {
        "metric": "numeric_match",
        "task87_threshold": 5,
        "task88_threshold": 15
      },
      "qmsum_meeting_qa_long": {
        "metric": "overlap_proxy",
        "threshold_range": [0.15, 0.40],
        "note": "Diagnostic only. Expected to be low (~0.26)."
      }
    },
    "latency_metrics": {
      "avg_generation_latency": "Required to be logged",
      "avg_e2e_latency": "Required to be logged",
      "avg_T_compress": "Required to be logged",
      "avg_T_prefill": "Required to be logged"
    },
    "throughput_metrics": {
      "generation_tok_s": "Required to be logged",
      "e2e_tok_s": "Required to be logged"
    },
    "system_metrics": {
      "vram_allocated_mb": "Log if available",
      "vram_reserved_mb": "Log if available"
    },
    "overall": {
      "pass_fail_logic": "Pass if all conditions reach target row_count, empty outputs <= threshold, repetition counts <= threshold, hit cap <= threshold, and metrics logged."
    }
  }
}
